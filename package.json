{
  "name": "ds-token-monitor",
  "version": "1.0.0",
  "description": "DeepSeek Token Monitor - Real-time token usage widget",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.ds-monitor.app",
    "productName": "DS-Token-Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": null
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
